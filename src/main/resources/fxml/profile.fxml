<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button ?>
<?import javafx.scene.control.Hyperlink ?>
<?import javafx.scene.control.Label ?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField ?>

<VBox stylesheets="/css/style.css"  styleClass="root" alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgetapp.UI.ProfileController">
    <padding>
        <Insets bottom="20" left="30" right="30" top="20" />
    </padding>
    <Label text="User Profile" styleClass="title-label"/>

    <VBox spacing="5">
        <Label text="Full Name" styleClass="section-label"/>
        <TextField fx:id="nameField" prefHeight="35" promptText="Update Your Name"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Email" styleClass="section-label"/>
        <TextField fx:id="emailField" editable="false"  prefHeight="35" />
    </VBox>
    <VBox spacing="5">
        <Label text="Password" styleClass="section-label"/>
        <PasswordField fx:id="passwordField" editable="false"  prefHeight="35" />
    </VBox>
    <VBox spacing="5">
        <Label text="Currency" styleClass="section-label"/>
        <TextField fx:id="currencyField" prefHeight="35" promptText="Update currency (e.g EGP,USD)"/>
    </VBox>

    <Label fx:id="label" text=""/>
    <Button mnemonicParsing="false" styleClass="btn-success" onAction="#handleUpdateProfile" prefHeight="35.0" prefWidth="290.0"  text="Save" />
    <HBox alignment="CENTER" spacing="20" prefWidth="300">
        <Button mnemonicParsing="false" styleClass="btn-outline" onAction="#handleGoTODashboard" prefHeight="35.0" prefWidth="140.0" text="Dashboard" />

        <Button mnemonicParsing="false" styleClass="btn-danger" onAction="#handleSignOut" prefHeight="35.0" prefWidth="140.0" text="Sign Out" />
    </HBox>
</VBox>
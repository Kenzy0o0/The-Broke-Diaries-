<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox stylesheets="/css/style.css" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.budgetapp.UI.ReportScreen"
      spacing="15"
     >

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Back" onAction="#handleGoToDashboard"
                />
        <Label text="Reports and Analytics"
               />
    </HBox>

    <!-- Totals -->
    <HBox spacing="40" alignment="CENTER">
        <Label fx:id="totalIncomeLabel"/>
        <Label fx:id="totalExpenseLabel"/>
    </HBox>

    <!-- No data message -->
    <Label fx:id="noDataLabel" visible="false"/>

    <!-- Pie Chart -->
    <PieChart fx:id="expensePieChart"
              prefHeight="280"
              legendVisible="true"/>

    <!-- Bar Chart -->
    <BarChart fx:id="incomeVsExpenseChart" prefHeight="280">
        <xAxis>
            <CategoryAxis fx:id="xAxis" label="Month"/>
        </xAxis>
        <yAxis>
            <NumberAxis fx:id="yAxis" label="Amount"/>
        </yAxis>
    </BarChart>

    <!-- Insight -->
    <Label fx:id="insightLabel"/>

</VBox>
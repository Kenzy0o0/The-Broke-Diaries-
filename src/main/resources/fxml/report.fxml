<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="/css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.budgetapp.UI.ReportScreen"
      spacing="15" 
      styleClass="root"
     >

    <padding>
        <Insets bottom="20" left="30" right="30" top="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Back" onAction="#handleGoToDashboard" styleClass="btn-outline"
                />
        <Label text="Reports and Analytics" styleClass="title-label"
               />
    </HBox>

    <!-- Totals -->
    <HBox spacing="40" alignment="CENTER">
        <Label fx:id="totalIncomeLabel" styleClass="income-amount"/>
        <Label fx:id="totalExpenseLabel" styleClass="expense-amount"/>
    </HBox>

    <!-- No data message -->
    <Label fx:id="noDataLabel" styleClass="msg-error" visible="false" styleClass="section-label"/>

    <!-- Pie Chart -->
    <PieChart fx:id="expensePieChart"
              prefHeight="280"
              legendVisible="true"/>

    <!-- Bar Chart -->
    <BarChart fx:id="incomeVsExpenseChart" prefHeight="280">
        <xAxis>
            <CategoryAxis fx:id="xAxis" label="Month"/>
        </xAxis>
        <yAxis>
            <NumberAxis fx:id="yAxis" label="Amount"/>
        </yAxis>
    </BarChart>

    <!-- Insight -->
    <Label fx:id="insightLabel"styleClass="section-label"/>

</VBox>
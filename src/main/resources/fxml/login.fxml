<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button ?>
<?import javafx.scene.control.Hyperlink ?>
<?import javafx.scene.control.Label ?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField ?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane fitToWidth="true" 
fitToHeight="true"

            prefHeight="650.0" 
            prefWidth="900.0" 
            stylesheets="/css/style.css" 
            styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.budgetapp.UI.LoginController">

    <!-- The VBox now acts as the main content area -->
    <content>
        <VBox styleClass="main-container" alignment="CENTER">
    <Label text="The Broke Diaries" styleClass="title-label" />
    <Label text="Login" styleClass="section-label" />

    <VBox spacing="5">
        <Label text="Email " styleClass="field-label"/>
        <TextField fx:id="emailField" prefHeight="35" promptText="Enter Your Email"/>
    </VBox>
    <VBox spacing="5">
        <Label text="Password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" prefHeight="35" promptText="Enter Your Password"/>
    </VBox>

    <Label fx:id="label" text=""/>
    <Button mnemonicParsing="false" text="Login" styleClass="btn-primary" onAction="#handleLoginAction" prefHeight="35.0" prefWidth="290.0"  />
    <Hyperlink onAction="#handleGoToRegister" styleClass="link-label" text="Don't have an account?" />
</VBox>

</content></ScrollPane>